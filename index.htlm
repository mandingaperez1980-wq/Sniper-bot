<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"><meta name="theme-color" content="#22c55e"><title>Sniper</title><style>
*{margin:0;padding:0;box-sizing:border-box}body{background:#06080e;color:#dfe4ed;font-family:monospace;font-size:13px;padding:12px;min-height:100vh}
.c{background:#0b0e18;border:1px solid #1a2035;border-radius:10px;padding:14px;margin-bottom:10px}.t{color:#22c55e;font-weight:700;font-size:11px;letter-spacing:2px;margin-bottom:8px}
.b{display:block;width:100%;padding:14px;border-radius:8px;border:none;font-weight:800;font-size:14px;margin-top:8px;font-family:monospace;cursor:pointer}
.bg{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff}.br{background:#1a1020;border:1px solid #ef444444;color:#ef4444}
input{width:100%;padding:12px;border-radius:6px;background:#131828;border:1px solid #1a2035;color:#f97316;font-size:11px;font-family:monospace;margin:6px 0;word-break:break-all}
.s{padding:10px;border-radius:6px;font-size:12px;margin-bottom:6px}.so{background:#22c55e11;border:1px solid #22c55e33;color:#86efac}
.se{background:#ef444411;border:1px solid #ef444433;color:#fca5a5}.sw{background:#f0b90b11;border:1px solid #f0b90b33;color:#fde68a}
.log{background:#060810;border:1px solid #1a2035;border-radius:6px;padding:8px;max-height:300px;overflow-y:auto;font-size:10px;margin-top:8px}
.le{padding:2px 0;border-bottom:1px solid #1a203522}.bal{font-size:28px;font-weight:800;color:#fff;text-align:center;padding:12px 0}
#step{font-size:13px;color:#f0b90b;font-weight:700;text-align:center;padding:12px}
</style>
<script src="https://unpkg.com/@solana/web3.js@1.95.8/lib/index.iife.min.js"></script>
<script src="https://unpkg.com/bs58@6.0.0/dist/index.umd.js"></script>
</head><body>
<div class="c"><div style="display:flex;align-items:center;gap:8px"><div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#22c55e,#06b6d4);display:flex;align-items:center;justify-content:center;font-size:16px">🎯</div><div><div style="font-size:15px;font-weight:800;color:#22c55e">MOMENTUM SNIPER</div><div style="font-size:9px;color:#5c6478">v4 · Autónomo · GitHub Pages</div></div></div></div>
<div class="c"><div id="step">⏳ Cargando Solana Web3...</div></div>
<div class="c" id="cCard"><div class="t">🔑 WALLET</div>
<div class="sw s">⚠️ Wallet NUEVA dedicada. NUNCA la principal.</div>
<input type="text" id="pk" placeholder="Clave privada de Phantom (Solana)..." autocomplete="off" spellcheck="false">
<button class="b bg" id="cbtn" onclick="doConn()">🔑 CONECTAR</button><div id="cerr"></div></div>
<div class="c" id="iCard" style="display:none"><div class="t">✅ WALLET CONECTADA</div>
<div style="word-break:break-all;font-size:11px;color:#22c55e;background:#22c55e11;padding:8px;border-radius:4px" id="adr"></div>
<div class="bal" id="bl">— SOL</div>
<button class="b bg" id="bbtn" onclick="togBot()">▶ INICIAR BOT</button>
<button class="b br" onclick="disc()" style="margin-top:6px">Desconectar</button>
<div id="bst" style="margin-top:8px;font-size:11px;color:#5c6478"></div></div>
<div class="c"><div class="t">📋 ACTIVIDAD</div><div id="al" class="log"><div style="color:#5c6478">Esperando...</div></div></div>
<div style="text-align:center;color:#353b4f;font-size:8px;margin-top:10px">⚠️ RIESGO EXTREMO · NO ES ASESORAMIENTO · DYOR</div>
<script>
let KP=null,CN=null,PK='',BL=0,SM=true,bOn=false,bIv=null,pos=[],scN=0;
const SOL='So11111111111111111111111111111111111111112',DEX='https://api.dexscreener.com/latest/dex',E=0.15;
const RPCS=['https://mainnet.helius-rpc.com/?api-key=1d8740dc-e5f4-421c-b823-e1bad1889eff','https://api.mainnet-beta.solana.com','https://solana-rpc.publicnode.com','https://rpc.ankr.com/solana'];
function stp(m){document.getElementById('step').innerHTML=m}
function al(m,c='#a5f3fc'){const e=document.getElementById('al'),t=new Date().toLocaleTimeString();e.innerHTML=`<div class="le"><span style="color:#5c6478">[${t}]</span> <span style="color:${c}">${m}</span></div>`+e.innerHTML;if(e.children.length>100)e.removeChild(e.lastChild)}

function d58(s){s=s.trim().replace(/\s/g,'');const M={};'123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz'.split('').forEach((c,i)=>M[c]=i);let z=0;for(let i=0;i<s.length&&s[i]==='1';i++)z++;const sz=Math.ceil(s.length*733/1000)+1;const b=new Uint8Array(sz);for(let i=0;i<s.length;i++){const ch=M[s[i]];if(ch===undefined)throw new Error('Carácter inválido: '+s[i]);let carry=ch;for(let j=sz-1;j>=0;j--){carry+=58*b[j];b[j]=carry%256;carry=Math.floor(carry/256)}}let st=0;while(st<sz&&b[st]===0)st++;const r=new Uint8Array(z+sz-st);for(let i=z+sz-st-1,j=sz-1;j>=st;i--,j--)r[i]=b[j];return r}

async function doConn(){const btn=document.getElementById('cbtn'),inp=document.getElementById('pk'),err=document.getElementById('cerr');
const pk=inp.value.trim().replace(/\s+/g,'');btn.textContent='⏳...';btn.disabled=true;err.innerHTML='';stp('⏳ Procesando...');
await new Promise(r=>setTimeout(r,100));
try{if(!pk)throw new Error('Pegá tu clave privada');if(pk.length<60)throw new Error('Clave corta ('+pk.length+' chars). Necesita ~87');if(pk.includes(' '))throw new Error('Tiene espacios. Es la seed phrase, no la clave privada');
stp('⏳ Decodificando...');await new Promise(r=>setTimeout(r,50));
let sk;if(window.bs58){try{sk=window.bs58.decode(pk)}catch(_){sk=d58(pk)}}else{sk=d58(pk)}
if(sk.length!==64)throw new Error('Decodificada: '+sk.length+' bytes (necesita 64)');
stp('⏳ Keypair...');await new Promise(r=>setTimeout(r,50));
if(!window.solanaWeb3)throw new Error('Solana Web3 no cargó. Recargá.');
KP=solanaWeb3.Keypair.fromSecretKey(sk);PK=KP.publicKey.toString();
al('✅ Keypair: '+PK.slice(0,6)+'...'+PK.slice(-6),'#86efac');
stp('⏳ Balance...');await new Promise(r=>setTimeout(r,50));
let got=false;
for(const rpc of RPCS){try{CN=new solanaWeb3.Connection(rpc,'confirmed');const lam=await CN.getBalance(KP.publicKey);BL=lam/solanaWeb3.LAMPORTS_PER_SOL;got=true;al('✅ RPC: '+rpc.split('/')[2]+' | '+BL.toFixed(4)+' SOL','#86efac');break}catch(e){al('RPC '+rpc.split('/')[2]+': '+e.message.slice(0,60),'#fde68a')}}
if(!got){al('⚠️ Balance no obtenido — intentará operar igual','#fde68a');CN=new solanaWeb3.Connection(RPCS[0],'confirmed')}
SM=false;try{localStorage.setItem('sp',pk)}catch(_){}
stp('✅ Conectada — Listo');
document.getElementById('cCard').style.display='none';document.getElementById('iCard').style.display='block';
document.getElementById('adr').textContent=PK;document.getElementById('bl').textContent=BL.toFixed(4)+' SOL';
}catch(e){stp('❌ '+e.message);err.innerHTML='<div class="se s" style="margin-top:8px">❌ '+e.message+'</div>';al('Error: '+e.message,'#fca5a5');btn.textContent='🔑 CONECTAR';btn.disabled=false}}

function disc(){KP=null;CN=null;PK='';BL=0;SM=true;if(bOn)togBot();try{localStorage.removeItem('sp')}catch(_){}
document.getElementById('cCard').style.display='block';document.getElementById('iCard').style.display='none';
document.getElementById('pk').value='';document.getElementById('cbtn').textContent='🔑 CONECTAR';document.getElementById('cbtn').disabled=false;stp('Desconectada')}

async function jSwap(addr,amt,buy){const iM=buy?SOL:addr,oM=buy?addr:SOL,am=buy?Math.floor(amt*solanaWeb3.LAMPORTS_PER_SOL):Math.floor(amt*1e6);
if(SM||!KP){al('[SIM] '+(buy?'BUY':'SELL')+' '+amt.toFixed(4)+'◎','#06b6d4');return{ok:true}}
try{al('Jupiter quote...');
const qr=await fetch('https://quote-api.jup.ag/v6/quote?inputMint='+iM+'&outputMint='+oM+'&amount='+am+'&slippageBps=500',{signal:AbortSignal.timeout(15000)});
if(!qr.ok)throw new Error('Q:'+qr.status);const q=await qr.json();if(q.error)throw new Error(q.error);
const sr=await fetch('https://quote-api.jup.ag/v6/swap',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({quoteResponse:q,userPublicKey:PK,wrapAndUnwrapSol:true,dynamicComputeUnitLimit:true,prioritizationFeeLamports:'auto'}),signal:AbortSignal.timeout(15000)});
if(!sr.ok)throw new Error('S:'+sr.status);const sd=await sr.json();if(sd.error)throw new Error(sd.error);
const tx=solanaWeb3.VersionedTransaction.deserialize(Uint8Array.from(atob(sd.swapTransaction),c=>c.charCodeAt(0)));
tx.sign([KP]);const txId=await CN.sendRawTransaction(tx.serialize(),{skipPreflight:true,maxRetries:3});
al('✅ TX:'+txId.slice(0,20)+'...','#86efac');
setTimeout(async()=>{try{BL=(await CN.getBalance(KP.publicKey))/solanaWeb3.LAMPORTS_PER_SOL;document.getElementById('bl').textContent=BL.toFixed(4)+' SOL'}catch(_){}},5000);
return{ok:true,txId}}catch(e){al('Swap: '+e.message,'#fca5a5');return{ok:false}}}

async function cycle(){scN++;try{
const all=[];for(const q of['pump.fun SOL','solana meme']){try{const r=await fetch(DEX+'/search?q='+encodeURIComponent(q),{signal:AbortSignal.timeout(10000)});if(r.ok){const d=await r.json();all.push(...(d.pairs||[]).filter(p=>p.chainId==='solana'))}}catch(_){}}
const now=Date.now(),seen=new Set();
const tk=all.filter(p=>{if(!p||seen.has(p.pairAddress))return false;seen.add(p.pairAddress);const mc=p.marketCap||p.fdv||0;return mc>=5e5&&mc<=5e6&&(p.liquidity?.usd||0)>=1e4}).map(p=>{
const b5=p.txns?.m5?.buys||0,s5=p.txns?.m5?.sells||0,br=b5+s5>0?b5/(b5+s5):0,c5=p.priceChange?.m5||0,c1=p.priceChange?.h1||0;
let sc=0;if(br>.7)sc+=25;else if(br>.6)sc+=15;if(c5>5&&c1>10)sc+=25;else if(c5>2)sc+=15;if(b5+s5>50)sc+=15;else if(b5+s5>20)sc+=8;if((p.liquidity?.usd||0)>5e4)sc+=10;
return{sym:p.baseToken?.symbol||'?',addr:p.baseToken?.address||'',pr:+(p.priceUsd||0),mc:p.marketCap||p.fdv||0,liq:p.liquidity?.usd||0,br,c5,c1,sc,tx:b5+s5}}).sort((a,b)=>b.sc-a.sc);
if(scN%3===0)al('Scan #'+scN+' | '+tk.length+' tokens'+(tk[0]?' | Top:'+tk[0].sym+'('+tk[0].sc+')':''));

const eb=SM?5:BL;
if(tk.length&&pos.length<8&&eb>=E){const pick=tk.find(t=>t.sc>=55&&t.br>=.6&&!pos.find(p=>p.addr===t.addr));
if(pick&&pick.liq>=1e4&&(pick.mc<=0||pick.liq/pick.mc>=.03)){
al('🎯 SNIPE: '+pick.sym+' Sc:'+pick.sc+' Buy:'+Math.round(pick.br*100)+'%','#ec4899');
const r=await jSwap(pick.addr,E,true);if(r.ok){pos.push({sym:pick.sym,addr:pick.addr,ep:pick.pr,cp:pick.pr,pp:pick.pr,t1:false,t2:false,sd:0,rl:0});al('✅ '+pick.sym+' @ $'+pick.pr.toFixed(8)+' | '+E+'◎','#86efac')}}}

for(const p of[...pos]){try{const r=await fetch(DEX+'/tokens/'+p.addr,{signal:AbortSignal.timeout(5000)});if(r.ok){const d=await r.json();const pr=(d.pairs||[]).find(x=>x.chainId==='solana');if(pr)p.cp=+(pr.priceUsd||p.cp)}}catch(_){p.cp*=(1+(Math.random()-.46)*.012)}
if(p.cp>p.pp)p.pp=p.cp;const m=p.cp/p.ep;
if(m>=2&&!p.t1){p.t1=true;const v=E*m*.5;await jSwap(p.addr,v,false);p.sd+=50;p.rl+=v;al('💰 '+p.sym+' TP1 2x → 50%','#06b6d4')}
else if(m>=3&&!p.t2){p.t2=true;const v=E*m*.25;await jSwap(p.addr,v,false);p.sd+=25;p.rl+=v;al('💰 '+p.sym+' TP2 3x → 25%','#06b6d4')}
else if(m<=.65&&p.sd<100){const v=E*m*(100-p.sd)/100;await jSwap(p.addr,v,false);p.sd=100;p.rl+=v;al('🛑 '+p.sym+' SL '+(((m-1)*100).toFixed(0))+'%','#fca5a5');pos=pos.filter(x=>x.addr!==p.addr)}
else if(m>=1.5){const dr=((p.pp-p.cp)/p.pp)*100;if(dr>=25&&p.sd<100){const v=E*m*(100-p.sd)/100;await jSwap(p.addr,v,false);p.sd=100;p.rl+=v;al('📉 '+p.sym+' Trail','#fde68a');pos=pos.filter(x=>x.addr!==p.addr)}}}
pos=pos.filter(p=>p.sd<100);
const bs=document.getElementById('bst');if(bs)bs.innerHTML='Scan #'+scN+' | Pos:'+pos.length+'/8 | '+pos.map(p=>p.sym+':'+(p.cp/p.ep).toFixed(2)+'x').join(' ');
stp(bOn?'🤖 Activo #'+scN+' | '+tk.length+'tk | '+pos.length+'pos':'Off')
}catch(e){al('Err: '+e.message,'#fca5a5')}}

function togBot(){const btn=document.getElementById('bbtn');if(bOn){clearInterval(bIv);bOn=false;btn.textContent='▶ INICIAR BOT';btn.className='b bg';al('🤖 Stop','#fde68a')}
else{bOn=true;btn.textContent='⏹ DETENER';btn.className='b br';al('🤖 Bot autónomo — scan cada 30s','#86efac');cycle();bIv=setInterval(cycle,30000)}}

window.addEventListener('load',async()=>{let t=0;while(!window.solanaWeb3&&t<20){await new Promise(r=>setTimeout(r,500));t++}
if(window.solanaWeb3){stp('✅ Listo — Pegá clave y tocá CONECTAR');al('Solana Web3 ✓','#86efac')}else{stp('❌ Web3 no cargó — Recargá');al('Error lib','#fca5a5')}
try{const s=localStorage.getItem('sp');if(s&&window.solanaWeb3){document.getElementById('pk').value=s;await new Promise(r=>setTimeout(r,500));await doConn()}}catch(_){}})
</script></body></html>
